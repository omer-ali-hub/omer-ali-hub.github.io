<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  {# Same stack as style.css / index.html (Inter via Google Fonts) #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {# Include italic weights — WeasyPrint needs real italic faces (font-style alone is unreliable). #}
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
  <style>
    @page { margin: 0.65in 0.75in; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      font-size: 9.5pt;
      line-height: 1.45;
      color: #111;
    }
    h1 {
      font-size: 15pt;
      font-weight: 600;
      margin: 0 0 0.5em 0;
      text-align: center;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    }
    h2 {
      font-size: 10pt;
      font-weight: 600;
      margin: 1em 0 0.3em 0;
      border-bottom: 1px solid #ccc;
      padding-bottom: 0.12em;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    }
    .contact-block {
      text-align: left;
      margin-bottom: 0.75em;
      font-size: 9pt;
    }
    .contact-block .addr { margin: 0.18em 0; }
    .contact-block .email { margin-top: 0.35em; }
    .cv-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 1.25em;
      margin: 0.32em 0;
      font-size: 9.5pt;
    }
    .cv-left { flex: 1; min-width: 0; }
    .cv-right {
      flex-shrink: 0;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }
    .edu-row .cv-edu-left {
      flex: 1;
      min-width: 0;
    }
    /* Publication / WP / WIP: stacked lines */
    .pub-entry, .wp-entry, .wip-entry {
      margin: 0.55em 0 0.72em 0;
    }
    .pub-title, .wp-title, .wip-title {
      font-weight: 600;
    }
    .pub-authors, .wp-authors, .wip-authors {
      margin: 0.2em 0 0 0;
      padding-left: 0;
      font-weight: 400;
    }
    .pub-journal {
      margin: 0.2em 0 0 0;
    }
    .wp-status {
      margin: 0.22em 0 0 0;
      font-style: italic;
      font-weight: 400;
    }
    .wp-status em {
      font-style: italic;
      font-weight: inherit;
    }
    .grant { margin: 0.32em 0; font-size: 9.5pt; }
    a { color: #0b57d0; text-decoration: none; }
    .footer-updated {
      margin-top: 1.35em;
      text-align: center;
      font-size: 8pt;
      color: #444;
    }
    .entry.teaching-entry { margin: 0.38em 0; font-size: 9.5pt; }
    em { font-style: italic; font-family: inherit; }
  </style>
</head>
<body>

  <h1>{{ meta.name }}</h1>

{% for sec in sections %}
  <h2>{{ sec.heading }}</h2>

  {% if sec.kind == 'contact' %}
    {% for item in sec.entries %}
    <div class="contact-block">
      {% for line in item.address_lines %}
      <div class="addr">{{ line }}</div>
      {% endfor %}
      {% if item.email %}
      <div class="email"><a href="mailto:{{ item.email }}">{{ item.email }}</a></div>
      {% endif %}
    </div>
    {% endfor %}

  {% elif sec.kind == 'experience' %}
    {% for item in sec.entries %}
    <div class="cv-row">
      <span class="cv-left">{{ item.left }}</span>
      <span class="cv-right">{{ item.right }}</span>
    </div>
    {% endfor %}

  {% elif sec.kind == 'education' %}
    {% for item in sec.entries %}
    <div class="cv-row edu-row">
      <span class="cv-edu-left"><strong>{{ item.degree }}</strong>{% if item.distinction %} {{ item.distinction }}{% endif %}, <em>{{ item.institution }}</em></span>
      <span class="cv-right">{{ item.year }}</span>
    </div>
    {% endfor %}

  {% elif sec.kind == 'publication' %}
    {% for item in sec.entries %}
    <div class="entry pub-entry">
      <div class="pub-title">{% if item.url %}<a href="{{ item.url }}">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}</div>
      {% if item.coauthors %}<div class="pub-authors">{{ item.coauthors }}</div>{% endif %}
      <div class="pub-journal"><em>{{ item.venue }}</em>, {{ item.year }}.</div>
    </div>
    {% endfor %}

  {% elif sec.kind == 'working_paper' %}
    {% for item in sec.entries %}
    <div class="entry wp-entry">
      <div class="wp-title">{% if item.url %}<a href="{{ item.url }}">{{ item.title }}</a>{% else %}{{ item.title }}{% endif %}</div>
      {% if item.coauthors %}<div class="wp-authors">{{ item.coauthors }}</div>{% endif %}
      {% if item.status %}<div class="wp-status"><em>{{ item.status }}</em></div>{% endif %}
    </div>
    {% endfor %}

  {% elif sec.kind == 'wip' %}
    {% for item in sec.entries %}
    <div class="entry wip-entry">
      <div class="wip-title">{{ item.title }}</div>
      {% if item.coauthors %}<div class="wip-authors">{{ item.coauthors }}</div>{% endif %}
    </div>
    {% endfor %}

  {% elif sec.kind == 'teaching' %}
    {% for item in sec.entries %}
    <div class="entry teaching-entry"><strong>{{ item.course }}</strong> — {{ item.detail }}</div>
    {% endfor %}

  {% elif sec.kind == 'grant' %}
    {% for item in sec.entries %}
    <div class="grant">{{ item.text }}</div>
    {% endfor %}

  {% endif %}
{% endfor %}

  <p class="footer-updated">Updated {{ updated_label }}</p>

</body>
</html>
